# ═══════════════════════════════════════════════════════════════
# ZARIWALA — .gitignore
# Keep this up to date. Never commit secrets or build artefacts.
# ═══════════════════════════════════════════════════════════════

# ── Environment / Secrets ───────────────────────────────────────
.env
.env.*
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.secret

# ── Dependencies ────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js Build Output ────────────────────────────────────────
/.next/
/out/
/build

# ── Prisma Generated Client ─────────────────────────────────────
/src/generated/prisma
/prisma/generated

# ── Testing / Coverage ──────────────────────────────────────────
/coverage

# ── Debug Logs ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── TypeScript ──────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Vercel ──────────────────────────────────────────────────────
.vercel

# ── OS / Editor Noise ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
